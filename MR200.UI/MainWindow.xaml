<Window x:Class="MR200.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:conv="clr-namespace:MR200.UI.Converters"
        xmlns:vm="clr-namespace:MR200.UI.ViewModels"
        Title="MR200 - Wood Cutting Machine Automation"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource LightBgBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:PageVisibilityConverter x:Key="PageVis"/>
        <conv:ActivePageConverter x:Key="ActivePage"/>

        <Style x:Key="AnimatedPage" TargetType="Grid">
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" From="30,0,0,0" To="0" Duration="0:0:0.35">
                                    <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Pulsing dot for live indicator -->
        <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.8" AutoReverse="True"/>
        </Storyboard>

        <!-- KPI Card hover scale -->
        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value></Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="{StaticResource LightBgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR ========== -->
            <Border Grid.Column="0" CornerRadius="8,0,0,8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0F2E28" Offset="0"/>
                        <GradientStop Color="#17463E" Offset="0.4"/>
                        <GradientStop Color="#1F5F5B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="0,24,0,24" HorizontalAlignment="Center">
                        <Grid Width="60" Height="60" Margin="0,0,0,8">
                            <Ellipse Width="60" Height="60" StrokeThickness="2">
                                <Ellipse.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E05C1A" Offset="0"/>
                                        <GradientStop Color="#C89B3C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                            </Ellipse>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                       Foreground="#E05C1A" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="GearRotation" Angle="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="GearRotation"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                        </Grid>
                        <TextBlock Text="MR200" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Slicing Machine" FontSize="10" Foreground="#7CBFB5" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Nav -->
                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                        <RadioButton Style="{StaticResource NavButton}" Content="Home" Tag="&#xE80F;"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource ActivePage}, ConverterParameter=Home}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Home"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="Charts" Tag="&#xE9D9;"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource ActivePage}, ConverterParameter=Charts}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Charts"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="History" Tag="&#xE81C;"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource ActivePage}, ConverterParameter=History}"
                                     Command="{Binding NavigateCommand}" CommandParameter="History"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="Maintenance" Tag="&#xE90F;"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource ActivePage}, ConverterParameter=Maintenance}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Maintenance"/>
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Margin="16,0,16,16">
                        <Separator Background="#2A6B60" Margin="0,0,0,8"/>
                        <TextBlock Text="Version: 2.0 Alpha" FontSize="9" Foreground="#5A9A90" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== MAIN CONTENT ========== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border Grid.Row="0" Background="White" Padding="16,0">
                    <Border.Effect><DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.04"/></Border.Effect>
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPage}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                            <!-- Live indicator when machine running -->
                            <Ellipse x:Name="LiveDot" Width="8" Height="8" Fill="#10B981" Margin="10,0,0,0"
                                     VerticalAlignment="Center" Visibility="Collapsed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    Background="Transparent" BorderThickness="0" Padding="10,4"
                                    Click="Minimize_Click" Cursor="Hand" Foreground="{StaticResource SubTextBrush}"/>
                            <Button Content="&#xE739;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    Background="Transparent" BorderThickness="0" Padding="10,4"
                                    Click="Maximize_Click" Cursor="Hand" Foreground="{StaticResource SubTextBrush}"/>
                            <Button Content="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    Background="Transparent" BorderThickness="0" Padding="10,4"
                                    Click="Close_Click" Cursor="Hand" Foreground="{StaticResource DangerRedBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16,12">
                    <Grid>

                        <!-- ==================== HOME PAGE ==================== -->
                        <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Home}"
                              Style="{StaticResource AnimatedPage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Title -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,0,12">
                                <Border Width="4" Height="30" CornerRadius="2" Background="{StaticResource PrimaryAccentBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Home Panel" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                            </StackPanel>

                            <!-- Row 1: Wood Selection + Machine Controls -->
                            <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,8">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Choose type of wood to process:"/>
                                        <ComboBox ItemsSource="{Binding WoodTypes}" SelectedIndex="{Binding SelectedWoodIndex}"
                                                  Padding="8,6" FontSize="12" Margin="0,4,0,10"/>
                                        <UniformGrid Columns="3" Margin="0,0,0,8">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Shear Yield Stress [MPa]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding ShearYieldStressDisplay}" FontWeight="SemiBold" Foreground="{StaticResource SlateBlkBrush}" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Specific Work [J/m²]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding SpecificWorkDisplay}" FontWeight="SemiBold" Foreground="{StaticResource SlateBlkBrush}" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Coeff. of Friction:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding CoeffFrictionDisplay}" FontWeight="SemiBold" Foreground="{StaticResource SlateBlkBrush}" FontSize="12"/>
                                            </StackPanel>
                                        </UniformGrid>
                                        <Button Content="Calculate Forces" Style="{StaticResource AccentButton}"
                                                Command="{Binding CalculateForcesCommand}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Machine Control"/>
                                        <WrapPanel Margin="0,6,0,0">
                                            <Button Content="&#xE768;  Start" Style="{StaticResource SuccessButton}" Command="{Binding StartMachineCommand}" Margin="0,0,8,6"/>
                                            <Button Content="&#xE71A;  Stop" Style="{StaticResource DangerButton}" Command="{Binding StopMachineCommand}" Margin="0,0,8,6"/>
                                            <Button Content="&#xE73B;  End Process" Style="{StaticResource TealButton}" Command="{Binding EndProcessCommand}" Margin="0,0,8,6"/>
                                        </WrapPanel>
                                        <Border Background="#F0FDF4" CornerRadius="10" Padding="14,10" Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                           Foreground="{StaticResource SuccessGreenBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="Machine Timer" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                                                    <TextBlock Text="{Binding TimeCounter}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Row 2: Three columns - Forces / Tool Props / Calculated -->
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Cutting Forces"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Cutting Force [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CuttingForceDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Text="Active Force [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ActiveForceDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Text="Friction on Rake [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrictionForceRakeDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="3" Text="Thrust Force [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ThrustForceDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="4" Text="Shear Force [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ShearForceDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="5" Text="Normal to Shear [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding NormalShearDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="6" Text="Normal to Rake [N]:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding NormalRakeDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Cutting Tool Properties"/>
                                        <UniformGrid Columns="3" Margin="0,4">
                                            <StackPanel Margin="0,3"><TextBlock Text="Feed Velocity [m/min]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding FeedVelocityDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Cutting Velocity [m/min]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding MaxCuttingVelocityDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Feed per teeth [m/tooth]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding FeedPerTeethDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Rotations [RPM]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding NumberOfRotationsDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Number of blades:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding NumberOfBladesDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Volumetric rate [m³/hr]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding VolumetricRateDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Mean Chip Thickness [m]:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding MeanChipThicknessDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                            <StackPanel Margin="0,3"><TextBlock Text="Teeth in Cutting:" Style="{StaticResource ValueLabel}" FontSize="10.5"/>
                                                <TextBlock Text="{Binding NumberOfTeethDisplay}" FontWeight="SemiBold" FontSize="11.5"/></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Calculated Properties"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                                <RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Friction Angle:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrictionAngleDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Text="Shear Angle:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ShearAngleDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Text="Friction Corr. Coeff:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrictionCorrCoeffDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="3" Text="Shearing Strain:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ShearingStrainDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="4" Text="Enter Angle:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EnterAngleDisplay}" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Grid.Row="5" Text="Exit / Center Angle:" Style="{StaticResource ValueLabel}" FontSize="11"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" FontWeight="SemiBold" FontSize="11">
                                                <Run Text="{Binding ExitAngleDisplay, Mode=OneWay}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding CenterCuttingAngleDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Row 3: Angles Table -->
                            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="6,0,6,8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="Teeth Angles Shared in Cutting"/>
                                    <DataGrid ItemsSource="{Binding AngleChipRows}" Style="{StaticResource ModernDataGrid}" MaxHeight="160">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Angle [Degrees]" Binding="{Binding Angle, StringFormat=F4}" Width="*"/>
                                            <DataGridTextColumn Header="Chip Thickness [Meter]" Binding="{Binding ChipThickness, StringFormat=E6}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Row 4: Charts -->
                            <UniformGrid Grid.Row="4" Columns="2" Margin="0,0,0,8">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Cutting Force vs Chip Thickness"/>
                                        <TextBlock Margin="0,0,0,4" FontSize="11">
                                            <Run Text="Fc(h): " FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                                            <Run Text="{Binding CuttingForceFuncDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                        <lvc:CartesianChart Series="{Binding CuttingForceSeries}" Height="240" ZoomMode="X"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Shaft Moment vs Chip Thickness"/>
                                        <TextBlock Margin="0,0,0,4" FontSize="11">
                                            <Run Text="T(h): " FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                                            <Run Text="{Binding ShaftTorqueFuncDisplay, Mode=OneWay}"/>
                                            <Run Text="   Max [N.m]: " FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                                            <Run Text="{Binding MaxShaftTorqueDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                        <lvc:CartesianChart Series="{Binding MomentSeries}" Height="240" ZoomMode="X"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Row 5: Force DataGrid -->
                            <Border Grid.Row="5" Style="{StaticResource Card}" Margin="6,0,6,8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="Force Components for Each Angle"/>
                                    <DataGrid ItemsSource="{Binding ForceRows}" Style="{StaticResource ModernDataGrid}" MaxHeight="220">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Theta" Binding="{Binding Theta, StringFormat=F4}" Width="*"/>
                                            <DataGridTextColumn Header="Cutting Force" Binding="{Binding CuttingForce, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Active Force" Binding="{Binding ActiveForce, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Friction" Binding="{Binding FrictionForce, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Thrust" Binding="{Binding ThrustForce, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Shear" Binding="{Binding ShearForce, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Normal Shear" Binding="{Binding NormalShear, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Normal Rake" Binding="{Binding NormalRake, StringFormat=F2}" Width="*"/>
                                            <DataGridTextColumn Header="Moment" Binding="{Binding CuttingForceMoment, StringFormat=F4}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ==================== CHARTS PAGE ==================== -->
                        <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Charts}"
                              Style="{StaticResource AnimatedPage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,0,12">
                                <Border Width="4" Height="30" CornerRadius="2" Background="{StaticResource PrimaryAccentBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Machine Performance" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                            </StackPanel>

                            <!-- Timer + quick stats -->
                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,8">
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#FFF7ED" CornerRadius="12" Width="48" Height="48" Margin="0,0,12,0">
                                            <TextBlock Text="&#xE121;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="{StaticResource PrimaryAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Elapsed Time" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                                            <TextBlock Text="{Binding TimeCounter}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#F0FDF4" CornerRadius="12" Width="48" Height="48" Margin="0,0,12,0">
                                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="{StaticResource SuccessGreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Feed Velocity" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                                            <TextBlock Text="{Binding FeedVelocityDisplay}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                            <TextBlock Text="m/min" FontSize="9" Foreground="{StaticResource SubTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#EFF6FF" CornerRadius="12" Width="48" Height="48" Margin="0,0,12,0">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="{StaticResource SlateBlkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Rotations" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                                            <TextBlock Text="{Binding NumberOfRotationsDisplay}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                            <TextBlock Text="RPM" FontSize="9" Foreground="{StaticResource SubTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Charts -->
                            <UniformGrid Grid.Row="2" Columns="2">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Simulated Shaft Torque vs Time"/>
                                        <lvc:CartesianChart Series="{Binding TorqueSeries}" Height="320" ZoomMode="X"
                                                            AnimationsSpeed="0:0:0.3"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Production Line vs Time"/>
                                        <lvc:CartesianChart Series="{Binding ProductionSeries}" Height="320" ZoomMode="X"
                                                            AnimationsSpeed="0:0:0.3"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>

                        <!-- ==================== HISTORY PAGE ==================== -->
                        <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=History}"
                              Style="{StaticResource AnimatedPage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,0,12">
                                <Border Width="4" Height="30" CornerRadius="2" Background="{StaticResource PrimaryAccentBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Process History Dashboard" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                            </StackPanel>

                            <!-- KPI Row 1: Main metrics with animated hover -->
                            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,8">
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Grid>
                                            <Border Background="#FFF7ED" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Left">
                                                <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                           Foreground="{StaticResource PrimaryAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Total Fees" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,8,0,2"/>
                                        <TextBlock Text="{Binding TotalFeesCard}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Border Background="#FFFBEB" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Left">
                                            <TextBlock Text="&#xEA80;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource SoftGoldBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Consumed Energy" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,8,0,2"/>
                                        <TextBlock Text="{Binding ConsumedEnergyCard}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Border Background="#F0FDF4" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Left">
                                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource SuccessGreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Production Volume" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,8,0,2"/>
                                        <TextBlock Text="{Binding ProductionVolumeCard}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Border Background="#EFF6FF" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Left">
                                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{StaticResource SlateBlkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Total Processes" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,8,0,2"/>
                                        <TextBlock Text="{Binding TotalProcessesCard}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- KPI Row 2: Force analysis summary cards -->
                            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,8">
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Avg Cutting Force"/>
                                        <TextBlock Text="{Binding AvgCuttingForceCard}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                                        <TextBlock Text="Newton (across all processes)" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                                        <Border Background="{StaticResource LightBgBrush}" CornerRadius="6" Padding="8,4" Margin="0,6,0,0" HorizontalAlignment="Left">
                                            <TextBlock FontSize="10">
                                                <Run Text="Max: " Foreground="{StaticResource SubTextBrush}"/>
                                                <Run Text="{Binding MaxCuttingForceCard, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource DangerRedBrush}"/>
                                                <Run Text=" N" Foreground="{StaticResource SubTextBrush}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Avg Cutting Moment"/>
                                        <TextBlock Text="{Binding AvgCuttingMomentCard}" FontSize="26" FontWeight="Bold" Foreground="#17463E"/>
                                        <TextBlock Text="N.m (shaft torque)" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                                        <Border Background="{StaticResource LightBgBrush}" CornerRadius="6" Padding="8,4" Margin="0,6,0,0" HorizontalAlignment="Left">
                                            <TextBlock FontSize="10">
                                                <Run Text="Max: " Foreground="{StaticResource SubTextBrush}"/>
                                                <Run Text="{Binding MaxCuttingMomentCard, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource DangerRedBrush}"/>
                                                <Run Text=" N.m" Foreground="{StaticResource SubTextBrush}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Energy Efficiency"/>
                                        <TextBlock Text="{Binding EnergyEfficiencyCard}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource SuccessGreenBrush}"/>
                                        <TextBlock Text="m³ / kWh" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                                        <Border Background="{StaticResource LightBgBrush}" CornerRadius="6" Padding="8,4" Margin="0,6,0,0" HorizontalAlignment="Left">
                                            <TextBlock FontSize="10">
                                                <Run Text="Avg Cost/m³: " Foreground="{StaticResource SubTextBrush}"/>
                                                <Run Text="{Binding AvgCostPerM3Card, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource SoftGoldBrush}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Charts Row: Production History + Wood Type Distribution -->
                            <UniformGrid Grid.Row="3" Columns="2" Margin="0,0,0,8">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Production History Trend"/>
                                        <lvc:CartesianChart Series="{Binding HistoryProductionSeries}" Height="250"
                                                            ZoomMode="X" AnimationsSpeed="0:0:0.5"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Wood Type Distribution"/>
                                        <lvc:PieChart Series="{Binding WoodTypePieSeries}" Height="250"
                                                      AnimationsSpeed="0:0:0.6"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- History DataGrid -->
                            <Border Grid.Row="4" Style="{StaticResource Card}" Margin="6,0,6,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource SectionHeader}" Text="Process Records" Margin="0"/>
                                        <Border Background="{StaticResource LightBgBrush}" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock FontSize="10">
                                                <Run Text="{Binding TotalProcessesCard, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text=" records" Foreground="{StaticResource SubTextBrush}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding HistoryRows}" Style="{StaticResource ModernDataGrid}" MaxHeight="300">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding ProcessNo}" Width="50"/>
                                            <DataGridTextColumn Header="Wood Type" Binding="{Binding WoodType}" Width="*"/>
                                            <DataGridTextColumn Header="Dimension" Binding="{Binding ProductDimension}" Width="85"/>
                                            <DataGridTextColumn Header="Volume" Binding="{Binding ProductionVolume, StringFormat=F3}" Width="75"/>
                                            <DataGridTextColumn Header="Fees" Binding="{Binding TotalFees, StringFormat=F2}" Width="75"/>
                                            <DataGridTextColumn Header="kWh" Binding="{Binding ConsumedElectricity, StringFormat=F2}" Width="70"/>
                                            <DataGridTextColumn Header="Start" Binding="{Binding StartAt}" Width="120"/>
                                            <DataGridTextColumn Header="End" Binding="{Binding EndAt}" Width="120"/>
                                            <DataGridTemplateColumn Header="Actions" Width="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="View" FontSize="10" Padding="6,2" Cursor="Hand"
                                                                Style="{StaticResource TealButton}"
                                                                Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding ProcessNo}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ==================== MAINTENANCE PAGE ==================== -->
                        <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Maintenance}"
                              Style="{StaticResource AnimatedPage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,0,12">
                                <Border Width="4" Height="30" CornerRadius="2" Background="{StaticResource PrimaryAccentBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Maintenance" FontSize="24" FontWeight="Bold" Foreground="{StaticResource DarkTextBrush}"/>
                            </StackPanel>

                            <!-- Machine specs info cards -->
                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,8">
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Border Background="#FFF7ED" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,8">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                       Foreground="{StaticResource PrimaryAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Blade Configuration" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource DarkTextBrush}"/>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Diameter: "/><Run Text="350 mm" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Teeth: "/><Run Text="20" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Kerf: "/><Run Text="3.9 mm" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Blades: "/><Run Text="10" FontWeight="SemiBold"/></TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Border Background="#F0FDF4" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,8">
                                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                       Foreground="{StaticResource SuccessGreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Operating Parameters" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource DarkTextBrush}"/>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Feed Velocity: "/><Run Text="11 m/min" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Cutting Velocity: "/><Run Text="64 m/sec" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Rake Angle: "/><Run Text="20°" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Depth of Cut: "/><Run Text="100 mm" FontWeight="SemiBold"/></TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <Border Background="#FFFBEB" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,8">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                       Foreground="{StaticResource SoftGoldBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Machine Status" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource DarkTextBrush}"/>
                                        <StackPanel Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Operational" FontSize="11" Foreground="{StaticResource SuccessGreenBrush}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Last Check: "/><Run Text="Today" FontWeight="SemiBold"/></TextBlock>
                                            <TextBlock Style="{StaticResource ValueLabel}" FontSize="11"><Run Text="Next Service: "/><Run Text="Scheduled" FontWeight="SemiBold"/></TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Maintenance placeholder -->
                            <Border Grid.Row="2" Style="{StaticResource Card}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30">
                                    <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                               Foreground="{StaticResource GrayBrush}" HorizontalAlignment="Center" Opacity="0.5"/>
                                    <TextBlock Text="Maintenance Scheduling" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource DarkTextBrush}" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                    <TextBlock Text="Preventive maintenance scheduling and blade wear tracking will be available in the next release."
                                               Foreground="{StaticResource SubTextBrush}" HorizontalAlignment="Center" TextAlignment="Center"
                                               MaxWidth="400" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
